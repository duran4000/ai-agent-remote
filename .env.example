# SSH 凭证配置模板
# 复制此文件为 .env 并填入实际凭证

# 本地项目路径（WSL 格式）
LOCAL_PROJECT_PATH=/mnt/c/path/to/ai-agent-remote

# 服务器配置
SERVER_HOST=your-server-ip
SERVER_PORT=22
SERVER_USER=your-username
SERVER_PASSWORD=your-password
SERVER_PATH=/home/your-username/ai-agent-remote

# PM2 配置
PM2_APP_NAME=ai-agent-remote

# 注意事项：
# 1. 此文件为模板，请勿提交实际凭证
# 2. 部署脚本会从 .env 文件读取凭证信息
# 3. 如需修改服务器配置，请修改 .env 文件
